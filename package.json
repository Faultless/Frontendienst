{
  "name": "frontendienst",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "harness/*", "harness/stacks/*"],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "site:dev": "bun run --filter @frontendienst/site dev",
    "site:build": "bun run --filter @frontendienst/site build",
    "verify": "bun run harness/verify/src/cli.ts"
  }
}
