---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { caseStudies } from "../../data/caseStudies";
import { projects } from "../../data/projects";
import { withBase } from "../../lib/base";
import { site } from "../../site.config";

export function getStaticPaths() {
  return caseStudies.map((cs) => ({ params: { slug: cs.slug }, props: { cs } }));
}

const { cs } = Astro.props;
const project = projects.find((p) => p.slug === cs.projectSlug);
---

<Layout title={`${cs.title} · case study · ${site.name}`} description={cs.subtitle}>
  <Header />
  <main>
    <article class="wrap study">
      <a href={withBase("/#work")} class="back">← All work</a>
      <span class="eyebrow">Case study</span>
      <h1>{cs.title}</h1>
      <p class="subtitle">{cs.subtitle}</p>

      <div class="actions">
        {cs.liveUrl && (
          <a href={cs.liveUrl} class="btn btn-primary" target="_blank" rel="noopener">
            {cs.liveLabel ?? "See it live"} ↗
          </a>
        )}
        <a href={`mailto:${site.email}`} class="btn btn-secondary">Build something like this</a>
      </div>

      <div class="hero-media">
        <img src={withBase(cs.hero)} alt={`${cs.title} screenshot`} />
      </div>

      <dl class="facts">
        {cs.facts.map(([label, value]) => (
          <div>
            <dt>{label}</dt>
            <dd>{value}</dd>
          </div>
        ))}
      </dl>

      {cs.sections.map((section) => (
        <section class="study-section">
          <h2>{section.heading}</h2>
          {section.body.map((paragraph) => <p>{paragraph}</p>)}
        </section>
      ))}

      <section class="study-section">
        <h2>In screenshots</h2>
        <div class="gallery">
          {cs.gallery.map((shot) => (
            <figure class:list={[{ portrait: shot.portrait }]}>
              <img src={withBase(shot.src)} alt={shot.caption} loading="lazy" />
              <figcaption>{shot.caption}</figcaption>
            </figure>
          ))}
        </div>
      </section>

      <section class="takeaway">
        <h2>Why this matters for your project</h2>
        <p>{cs.takeaway}</p>
        {project && (
          <div class="stack">
            {project.stack.map((t) => <span class="pill">{t}</span>)}
          </div>
        )}
        <div class="actions">
          {cs.liveUrl && (
            <a href={cs.liveUrl} class="btn btn-primary" target="_blank" rel="noopener">
              {cs.liveLabel ?? "See it live"} ↗
            </a>
          )}
          <a href={`mailto:${site.email}`} class="btn btn-secondary">{site.email}</a>
        </div>
      </section>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .study {
    padding-block: 72px 96px;
    max-width: 860px;
  }

  .back {
    display: inline-block;
    margin-bottom: 28px;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.92rem;
  }

  .back:hover {
    color: var(--text);
  }

  h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-top: 14px;
  }

  .subtitle {
    margin-top: 14px;
    font-size: 1.12rem;
    color: var(--text-dim);
    max-width: 640px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .hero-media {
    margin-top: 44px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .hero-media img {
    width: 100%;
    display: block;
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 18px 28px;
    margin: 36px 0 0;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-raised);
  }

  .facts dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }

  .facts dd {
    margin: 6px 0 0;
    font-size: 0.95rem;
    color: var(--text);
  }

  .study-section {
    margin-top: 56px;
  }

  .study-section h2 {
    font-size: 1.4rem;
  }

  .study-section h2::after {
    content: "";
    display: block;
    width: 44px;
    height: 3px;
    margin-top: 10px;
    border-radius: 2px;
    background: var(--gradient);
  }

  .study-section p {
    margin-top: 18px;
    color: var(--text-dim);
    line-height: 1.75;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 26px;
  }

  .gallery figure {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-raised);
  }

  .gallery img {
    width: 100%;
    display: block;
  }

  .gallery figure.portrait img {
    aspect-ratio: 9 / 19;
    object-fit: cover;
  }

  .gallery figcaption {
    padding: 12px 14px;
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .takeaway {
    margin-top: 64px;
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-raised);
  }

  .takeaway h2 {
    font-size: 1.25rem;
  }

  .takeaway p {
    margin-top: 14px;
    color: var(--text-dim);
    line-height: 1.7;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }
</style>
