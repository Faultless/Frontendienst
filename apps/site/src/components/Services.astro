---
const services = [
  {
    title: "Frontend Web Apps",
    blurb:
      "Production React/TypeScript front ends — component architecture, state management, and the unglamorous plumbing (auth, forms, data fetching) done right.",
    tags: ["React", "TypeScript", "Astro", "Three.js", "Vite", "MUI"],
  },
  {
    title: "Flutter Mobile Apps",
    blurb:
      "Cross-platform apps that ship to Android, iOS, web, and desktop from one codebase — custom rendering, offline-first data, and native-feeling interactions.",
    tags: ["Flutter", "Dart", "Riverpod", "go_router", "Hive"],
  },
  {
    title: "Interactive & Game Builds",
    blurb:
      "Canvas/WebGL-driven experiences beyond standard CRUD apps — custom physics, procedural rendering, and real-time interaction loops.",
    tags: ["Phaser", "WebGL", "Canvas", "WebAudio"],
  },
];

const traits = [
  "Comfortable dropping into an existing codebase, not just greenfield work",
  "Ships incrementally with tests and docs, not a black box at the end",
  "Handles a feature end-to-end — UI, state, data layer, and the edge cases",
  "Direct communication, realistic estimates, no scope surprises",
];
---

<section id="services">
  <div class="wrap">
    <span class="eyebrow">What I do</span>
    <h2 class="section-heading">One contractor, three surfaces you actually need covered.</h2>
    <p class="section-lede">
      Most teams don't need a specialist in exactly one framework — they need
      someone who can pick up the stack in front of them and deliver. Here's
      where I spend most of my time.
    </p>

    <div class="grid">
      {services.map((s) => (
        <div class="card service-card">
          <h3>{s.title}</h3>
          <p>{s.blurb}</p>
          <div class="tags">
            {s.tags.map((t) => <span class="pill">{t}</span>)}
          </div>
        </div>
      ))}
    </div>

    <ul class="traits">
      {traits.map((t) => <li>{t}</li>)}
    </ul>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 44px;
  }

  .service-card {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .service-card h3 {
    font-size: 1.15rem;
  }

  .service-card p {
    color: var(--text-dim);
    font-size: 0.95rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
    padding-top: 6px;
  }

  .traits {
    list-style: none;
    margin: 52px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px 28px;
  }

  .traits li {
    position: relative;
    padding-left: 22px;
    color: var(--text-dim);
    font-size: 0.95rem;
  }

  .traits li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gradient);
  }
</style>
