---
import type { Project } from "../data/projects";
import { withBase } from "../lib/base";

interface Props {
  project: Project;
  reverse?: boolean;
}

const { project, reverse = false } = Astro.props;
---

<article class:list={["project-card", { reverse }]} style={`--accent-local: ${project.accent}`}>
  <div class="media">
    {project.media.video ? (
      <video
        src={withBase(project.media.video)}
        poster={withBase(project.media.image)}
        autoplay
        muted
        loop
        playsinline
        controls
      />
    ) : (
      <img src={withBase(project.media.image)} alt={`${project.name} capture`} loading="lazy" />
    )}
  </div>

  <div class="content">
    <span class="pill platform-pill">{project.platform}</span>
    <h3>{project.name}</h3>
    <p class="tagline">{project.tagline}</p>
    <p class="description">{project.description}</p>

    <ul class="highlights">
      {project.highlights.map((h) => <li>{h}</li>)}
    </ul>

    <div class="stack">
      {project.stack.map((t) => <span class="pill">{t}</span>)}
    </div>

    {project.link && (
      <a href={project.link} class="btn btn-secondary link-btn" target="_blank" rel="noopener">
        View project ↗
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 44px;
    align-items: center;
    padding-block: 56px;
    border-bottom: 1px solid var(--border);
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-card.reverse {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
  }

  .project-card.reverse .media {
    order: 2;
  }

  .project-card.reverse .content {
    order: 1;
  }

  .media {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-raised);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.02), 0 20px 60px -30px var(--accent-local);
  }

  .media img,
  .media video {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .media-label {
    position: absolute;
    bottom: 10px;
    right: 10px;
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    background: rgba(11, 13, 18, 0.75);
    color: var(--text-faint);
    padding: 4px 9px;
    border-radius: 999px;
    border: 1px solid var(--border);
  }

  .content h3 {
    font-size: 1.7rem;
    margin-top: 12px;
    color: var(--text);
  }

  .platform-pill {
    border-color: var(--accent-local);
    color: var(--accent-local);
  }

  .tagline {
    margin-top: 8px;
    font-size: 1.02rem;
    color: var(--text);
    font-weight: 500;
  }

  .description {
    margin-top: 14px;
    color: var(--text-dim);
    font-size: 0.96rem;
  }

  .highlights {
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .highlights li {
    position: relative;
    padding-left: 20px;
    font-size: 0.9rem;
    color: var(--text-dim);
  }

  .highlights li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-local);
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .link-btn {
    margin-top: 22px;
  }

  @media (max-width: 860px) {
    .project-card,
    .project-card.reverse {
      grid-template-columns: 1fr;
    }

    .project-card.reverse .media,
    .project-card.reverse .content {
      order: initial;
    }
  }
</style>
